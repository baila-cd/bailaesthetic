{
  "setupTasks": [
    {
      "command": "pnpm install",
      "name": "Installing Dependencies"
    }
  ],

  "tasks": {
    "start": {
      "name": "start",
      "command": "pnpm start",
      "runAtStart": true
    },
    "build": {
      "name": "build",
      "command": "pnpm build",
      "runAtStart": false
    },
    "test": {
      "name": "test",
      "command": "pnpm test",
      "runAtStart": false
    },
    "eject": {
      "name": "eject",
      "command": "pnpm eject",
      "runAtStart": false
    }
  }
}
